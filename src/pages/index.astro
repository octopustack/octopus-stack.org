---
import Ecosystem from "../components/ecosystem.astro";
import Footer from "../components/footer.astro";
import Logo from "../components/logo.astro";
import Roadmap from "../components/roadmap.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta
            property="og:title"
            content="Cervid · Radical Infrastructure for Node.js"
        />
        <meta
            property="og:description"
            content="Zero-dependency, high-performance data infrastructure for Node.js. Built with SharedArrayBuffer, Workers and zero-copy architecture."
        />
        <meta property="og:image" content="/profile.png" />
        <meta property="og:url" content="https://cervid.io/" />
        <meta property="og:type" content="website" />
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Cervid · Radical Infrastructure for Node.js</title>
        <meta
            http-equiv="Content-Security-Policy"
            content="upgrade-insecure-requests"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
        />
        <link rel="stylesheet" href="styles/main.css" />
    </head>
    <body>
        <nav>
            <Logo />
            <div class="nav-right">
                <a href="https://github.com/CervidLabs" class="nav-link"
                    >GITHUB</a
                >
            </div>
        </nav>

        <header class="mother-hero">
            <div class="hero-content">
                <h1 class="hero-title">
                    <span class="line-1">RADICAL</span>
                    <span class="line-2">INFRASTRUCTURE</span>
                    <span class="line-3">FOR NODE.JS</span>
                </h1>

                <p class="hero-tagline">
                    Zero-dependency, high-performance data infrastructure for
                    Node.js. Built with SharedArrayBuffer, Workers and zero-copy
                    architecture.
                </p>

                <div class="hero-cta">
                    <a href="#ecosystem" class="btn-primary">GET STARTED</a>
                    <a
                        href="https://github.com/CervidLabs"
                        class="btn-secondary">GITHUB</a
                    >
                </div>
            </div>
        </header>
        <section class="philosophy">
            <div class="philosophy-item">
                <h3>01 // NATIVE CORE</h3>
                <p>
                    No native modules required. We leverage the power of modern
                    V8 features like SharedArrayBuffers and BigInt for maximum
                    portability.
                </p>
            </div>
            <div class="philosophy-item">
                <h3>02 // ZERO OVERHEAD</h3>
                <p>
                    Built for production. We focus on memory efficiency and
                    zero-copy data operations to minimize the impact on the
                    Garbage Collector.
                </p>
            </div>
            <div class="philosophy-item">
                <h3>03 // SCALE FIRST</h3>
                <p>
                    Designed to handle millions of rows in milliseconds. Every
                    library in the Cervid family is tested against massive
                    real-world datasets.
                </p>
            </div>
        </section>

        <Ecosystem />

        <Roadmap />

        <Footer />
    </body>
</html>
