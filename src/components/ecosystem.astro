---
const { disabled = [] } = Astro.props;

const modules = [
    {
        name: "data",
        href: "/data",
        status: "LIVE",
        version: "v1.0.0",
        description:
            "Ultra-fast columnar engine. Leveraging Shared Memory and Worker Threads.",
        tags: ["Columnar", "SIMD", "Workers", "CSV", "JSON", "NDJSON"],
    },
    {
        name: "decomposer",
        href: "/decomposer",
        status: "LIVE",
        version: "v0.1.0",
        description: "Binary format deconstruction. Pure Node.js reader.",
        tags: ["Binary", "Parquet", "IPC"],
    },
    {
        name: "vision",
        href: "/vision",
        status: "LIVE",
        version: "v0.0.1",
        description: "Image Processing Engine",
        tags: ["Image Processing", "CPU"],
    },
];
---

<!-- Overlay backdrop -->
<div class="ecosystem-backdrop" id="ecosystemBackdrop"></div>

<!-- Off-canvas Drawer -->
<aside class="ecosystem-drawer" id="ecosystemDrawer">
    <div class="drawer-header">
        <h3 class="drawer-title">CERVID ECOSYSTEM</h3>
        <button class="close-drawer" id="closeEcosystemBtn" aria-label="Close Ecosystem">✕</button>
    </div>
    
    <div class="drawer-body">
        <p class="drawer-desc">Select a library to explore its documentation and features.</p>
        <div class="drawer-list">
            {
                modules.map((mod) => {
                    const isDisabled = !mod.href;
                    const isCancel = disabled.includes(mod.name) || isDisabled;
                    const Tag = isDisabled ? "div" : "a";

                    return (
                        <Tag
                            href={!isCancel ? mod.href : undefined}
                            class={`sidebar-item ${isDisabled ? "blueprint" : "live"} ${disabled.includes(mod.name) ? "current" : ""}`}
                        >
                            <span class="status-indicator"></span>
                            <div class="sidebar-item-info">
                                <span class="mod-name">{mod.name}</span>
                                <span class="mod-version">{mod.version}</span>
                                <div class="sidebar-item-tags">
                                    {mod.tags.map((tag) => (
                                        <span>{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </Tag>
                    );
                })
            }
        </div>
    </div>
</aside>

<script>
    const drawer = document.getElementById("ecosystemDrawer");
    const backdrop = document.getElementById("ecosystemBackdrop");
    const closeBtn = document.getElementById("closeEcosystemBtn");
    
    // Select all buttons that might open it
    const openBtns = document.querySelectorAll("#openEcosystemBtn");

    function openDrawer() {
        drawer?.classList.add("active");
        backdrop?.classList.add("active");
        document.body.style.setProperty("overflow", "hidden");
    }

    function closeDrawer() {
        drawer?.classList.remove("active");
        backdrop?.classList.remove("active");
        document.body.style.setProperty("overflow", "auto");
    }

    openBtns.forEach(btn => btn.addEventListener("click", openDrawer));
    closeBtn?.addEventListener("click", closeDrawer);
    backdrop?.addEventListener("click", closeDrawer);
</script>
